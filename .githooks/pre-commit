#!/bin/sh
set -eu

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks is required by this repo's pre-commit hook." >&2
  echo "Install it, or run 'git commit --no-verify' only for an intentional emergency bypass." >&2
  exit 1
fi

blocked_path="$(git diff --cached --name-only | grep -E '(^|/)(\.env($|\.)|agentlog\.txt$)' | head -n 1 || true)"
if [ -n "$blocked_path" ]; then
  echo "Refusing to commit forbidden local artifact: $blocked_path" >&2
  exit 1
fi

gitleaks protect --staged --redact
